{
  "name": "@taps/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx ../../scripts/seed.ts",
    "workers": "tsx ../../scripts/run-workers.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@taps/config": "workspace:*",
    "@taps/contracts": "workspace:*",
    "@taps/db": "workspace:*",
    "@taps/domain": "workspace:*",
    "@taps/mcp": "workspace:*",
    "@taps/observability": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "bullmq": "^5.46.1",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.4.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3"
  }
}
