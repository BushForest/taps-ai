NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Sentry — client-side error reporting (safe to expose)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry — server-side error reporting (keep private)
SENTRY_DSN=

# SENTRY_AUTH_TOKEN — CI/CD build secret only; set in Vercel project settings and in the CI workflow
# environment. Never commit to source.
# SENTRY_ORG=tapseats
# SENTRY_PROJECT=taps-onboarding
